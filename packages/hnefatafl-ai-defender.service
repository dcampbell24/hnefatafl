[Unit]
Description=Copenhagen Hnefatafl AI
Documentation="https://hnefatafl.org"

[Service]
Type=simple
Restart=always
ExecStart=/usr/games/taflzero --username ${USERNAME} --password ${PASSWORD} --role defender --accept-games 1 --systemd
PrivateTmp=yes
InaccessibleDirectories=/home
DeviceAllow=/dev/null rw
EnvironmentFile=/etc/hnefatafl-ai-defender.conf
WorkingDirectory=/usr/share/taflzero

[Install]
WantedBy=multi-user.target
